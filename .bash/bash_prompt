function git_prompt() {
    # Fast exit: check for .git in current dir first (avoids git command)
    local git_dir
    if [[ -d .git ]]; then
        git_dir=".git"
    else
        # Only run git rev-parse if no local .git found
        git_dir=$(git rev-parse --git-dir 2>/dev/null) || return 0
    fi

    # Raw escape codes for echo (not PS1 wrapped)
    local color_clean=$'\e[0;32m'    # Green
    local color_staged=$'\e[0;36m'   # Cyan
    local color_unstaged=$'\e[0;31m' # Red
    local color_off=$'\e[0m'

    # Get branch from HEAD file directly (faster than git branch)
    local head_content branch git_color
    if [[ -r "$git_dir/HEAD" ]]; then
        read -r head_content < "$git_dir/HEAD"
        if [[ "$head_content" == ref:* ]]; then
            branch="${head_content##*/}"
        else
            # Detached HEAD - show short hash
            branch="${head_content:0:7}..."
        fi
    else
        branch="unknown"
    fi

    # Skip expensive git status if disabled via: git config --bool prompt.showinfo false
    if [[ "$(git config --local --bool prompt.showinfo 2>/dev/null)" == "false" ]]; then
        echo "[$branch]"
        return 0
    fi

    # Run git status with 5 second timeout
    local status pid
    status=$(
        git status --porcelain 2>/dev/null &
        pid=$!
        ( sleep 5; kill $pid 2>/dev/null ) &
        watchdog=$!
        wait $pid 2>/dev/null
        exit_code=$?
        kill $watchdog 2>/dev/null
        wait $watchdog 2>/dev/null
        exit $exit_code
    )

    # If git status timed out (killed), disable it for this repo
    if [[ $? -ne 0 && -z "$status" ]]; then
        git config --local --bool prompt.showinfo false
        echo -e "\n\e[0;33m[git-prompt] git status timed out - disabled for this repo.\e[0m"
        echo -e "\e[0;33mRe-enable with: git config --bool prompt.showinfo true\e[0m\n"
        echo "[$color_clean$branch$color_off]"
        return 0
    fi

    # Determine status color
    if [[ -z "$status" ]]; then
        git_color="$color_clean"
    elif [[ "$status" == *$'\n'[\ ][AMDRC?]* ]] || [[ "$status" == [\ ][AMDRC?]* ]]; then
        # Unstaged changes (space in first column, letter in second)
        git_color="$color_unstaged"
    else
        git_color="$color_staged"
    fi

    echo "[$git_color$branch$color_off]"
}

# Thy holy prompt - red for root
if [[ ${EUID} == 0 ]]; then
    PROMPT_COMMAND='PS1="${Red}\u@\h:\W$(git_prompt)\$ ${Color_Off}"'
else
    PROMPT_COMMAND='PS1="\u@\h:\W$(git_prompt)\$ "'
fi
