# disable console beep
set bell-style none
# set bell-style visible

# 8-bit character support
set input-meta on
set output-meta on

# Case-insensitive completion
set completion-ignore-case on

# Treat hyphens and underscores as equivalent in completion
set completion-map-case on

# Show all completions on first TAB instead of waiting for second
set show-all-if-ambiguous on

# Show all completions if no partial completion possible
set show-all-if-unmodified on

# Add trailing slash to completed directories
set mark-directories on
set mark-symlinked-directories on

# Color files by type during completion (like ls --color)
set colored-stats on

# Color the common prefix in completions
set colored-completion-prefix on

# Don't expand ~ to /home/user in completion
set expand-tilde off

# Faster completion (don't wait for more input)
set keyseq-timeout 50

# History search with arrow keys (type partial command, then up/down)
"\e[A": history-search-backward
"\e[B": history-search-forward

# allow the use of the Home/End keys
"\e[1~": beginning-of-line
"\e[4~": end-of-line
"\e[H": beginning-of-line
"\e[F": end-of-line

# allow the use of the Delete/Insert keys
"\e[3~": delete-char
"\e[2~": quoted-insert

# mappings for Ctrl-left-arrow and Ctrl-right-arrow for word moving
"\e[1;5C": forward-word
"\e[1;5D": backward-word
"\e[5C": forward-word
"\e[5D": backward-word
"\e\e[C": forward-word
"\e\e[D": backward-word

# Ctrl+L clears screen (explicit)
"\C-l": clear-screen